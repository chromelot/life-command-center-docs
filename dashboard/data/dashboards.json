{
  "_comment": "Dashboard layouts. EDIT THIS FILE to add/rearrange dashboards and widgets — no code changes needed. `group` buckets a dashboard in the sidebar (e.g. Personal / Work). Widget types: section | stat | goal | group | trend | progress | text | note. Reference a metric by its catalog key (metrics.json). 'field' selects the number for stat/goal/trend/progress: current (headline: latest for last-metrics, today for sum/count) | week (this-week aggregate). 'span' (1-4) = column width. Order in the array = order on screen.",
  "settings": {
    "refreshSeconds": 900,
    "columns": 4
  },
  "dashboards": [
    {
      "id": "personal-day",
      "group": "Personal",
      "title": "Personal — Today",
      "icon": "\u2600\ufe0f",
      "subtitle": "How today is going, at a glance.",
      "widgets": [
        { "type": "section", "title": "Morning" },
        {
          "type": "checklist",
          "title": "Morning stack",
          "span": 2,
          "items": [
            { "metric": "life.supplements_done", "label": "Supplements" },
            { "metric": "life.weigh_in_done", "label": "Weigh in" },
            { "metric": "life.morning_journal_done", "label": "Morning journal" },
            { "metric": "life.spirit_time_done", "label": "Spirit time" }
          ]
        },
        { "type": "section", "title": "Fitness" },
        { "type": "goal", "metric": "life.strength_sessions", "field": "current", "target": 1, "weekTargetMetric": "goal.strength_target", "label": "Strength" },
        { "type": "goal", "metric": "life.cardio_sessions", "field": "current", "target": 1, "weekTargetMetric": "goal.cardio_target", "label": "Cardio" },
        { "type": "stat", "metric": "personal.steps", "field": "current", "label": "Steps", "showTrend": false },
        { "type": "section", "title": "Nutrition" },
        {
          "type": "progressgroup",
          "title": "Calories & Protein",
          "span": 2,
          "items": [
            { "metric": "nutrition.calories", "field": "current", "target": "goal.calorie_target", "label": "Calories" },
            { "metric": "nutrition.protein_g", "field": "current", "targetValue": 150, "label": "Protein" }
          ]
        },
        {
          "type": "statlist",
          "title": "Macros",
          "span": 2,
          "items": [
            { "metric": "nutrition.protein_g", "field": "current", "label": "Protein" },
            { "metric": "nutrition.carbs_g", "field": "current", "label": "Carbs" },
            { "metric": "nutrition.fat_g", "field": "current", "label": "Fat" }
          ]
        },
        { "type": "section", "title": "Development work" },
        { "type": "stat", "metric": "dev.cl_dev_min", "field": "current", "label": "Chrome Lot", "showTrend": false },
        { "type": "stat", "metric": "dev.tg_dev_min", "field": "current", "label": "Turbo Gear", "showTrend": false },
        { "type": "stat", "metric": "dev.systems_min", "field": "current", "label": "Systems", "showTrend": false },
        { "type": "goal", "metric": "dev.total_dev_min", "field": "current", "target": 120, "weekTarget": 600, "label": "Total Dev" },
        { "type": "section", "title": "Ops" },
        { "type": "stat", "metric": "ops.todoist_done", "field": "current", "label": "Todoist Done", "showTrend": false },
        { "type": "stat", "metric": "dev.ops_min", "field": "current", "label": "Ops Time", "showTrend": false },
        { "type": "stat", "metric": "dev.field_min", "field": "current", "label": "Field Time", "showTrend": false },
        { "type": "goal", "metric": "dev.total_ops_work_min", "field": "current", "target": 120, "weekTarget": 600, "label": "Total Ops Work" },
        { "type": "section", "title": "Workshop & extras" },
        {
          "type": "group",
          "metrics": [
            { "metric": "dev.workshop_min", "field": "current", "label": "Workshop", "showTrend": false },
            { "metric": "life.small_talk", "field": "current", "label": "Small Talk", "showTrend": false },
            { "metric": "dev.reading_min", "field": "current", "label": "Reading", "showTrend": false }
          ]
        }
      ]
    },
    {
      "id": "personal-week",
      "group": "Personal",
      "title": "Personal — This Week",
      "icon": "\ud83c\udfaf",
      "subtitle": "This week's scorecard (starts Sunday) — where I'm on track and where to push. Same data as Today, pivoted to the week.",
      "widgets": [
        { "type": "section", "title": "Morning — days done this week" },
        {
          "type": "progressgroup",
          "title": "Morning stack (goal 6 days)",
          "span": 2,
          "items": [
            { "metric": "life.supplements_done", "field": "week", "targetValue": 6, "format": "integer", "label": "Supplements" },
            { "metric": "life.weigh_in_done", "field": "week", "targetValue": 6, "format": "integer", "label": "Weigh in" },
            { "metric": "life.morning_journal_done", "field": "week", "targetValue": 6, "format": "integer", "label": "Morning journal" },
            { "metric": "life.spirit_time_done", "field": "week", "targetValue": 6, "format": "integer", "label": "Spirit time" }
          ]
        },
        { "type": "section", "title": "Fitness" },
        {
          "type": "progressgroup",
          "title": "Workouts vs weekly goal",
          "span": 2,
          "items": [
            { "metric": "life.strength_sessions", "field": "week", "target": "goal.strength_target", "label": "Strength" },
            { "metric": "life.cardio_sessions", "field": "week", "target": "goal.cardio_target", "label": "Cardio" }
          ]
        },
        {
          "type": "statlist",
          "title": "Weekly averages",
          "span": 2,
          "items": [
            { "metric": "personal.steps", "field": "weekAvg", "label": "Steps / day" },
            { "metric": "personal.sleep_hours", "field": "weekAvg", "label": "Sleep / night", "minCount": 3 },
            { "metric": "personal.weight_lbs", "field": "weekAvg", "label": "Weight (avg)" },
            { "metric": "personal.body_fat_pct", "field": "weekAvg", "label": "Body fat (avg)" }
          ]
        },
        { "type": "section", "title": "Nutrition — daily average" },
        {
          "type": "progressgroup",
          "title": "Avg / day vs target",
          "span": 2,
          "items": [
            { "metric": "nutrition.calories", "field": "weekAvg", "target": "goal.calorie_target", "label": "Calories" },
            { "metric": "nutrition.protein_g", "field": "weekAvg", "targetValue": 150, "label": "Protein" }
          ]
        },
        {
          "type": "statlist",
          "title": "Avg macros / day",
          "span": 2,
          "items": [
            { "metric": "nutrition.protein_g", "field": "weekAvg", "label": "Protein" },
            { "metric": "nutrition.carbs_g", "field": "weekAvg", "label": "Carbs" },
            { "metric": "nutrition.fat_g", "field": "weekAvg", "label": "Fat" }
          ]
        },
        { "type": "section", "title": "Development work" },
        {
          "type": "progressgroup",
          "title": "Dev & ops time vs weekly goal",
          "span": 2,
          "items": [
            { "metric": "dev.total_dev_min", "field": "week", "targetValue": 600, "label": "Total Dev" },
            { "metric": "dev.total_ops_work_min", "field": "week", "targetValue": 600, "label": "Total Ops Work" }
          ]
        },
        {
          "type": "statlist",
          "title": "Dev breakdown (this week)",
          "span": 2,
          "items": [
            { "metric": "dev.cl_dev_min", "field": "week", "label": "Chrome Lot" },
            { "metric": "dev.tg_dev_min", "field": "week", "label": "Turbo Gear" },
            { "metric": "dev.systems_min", "field": "week", "label": "Systems" }
          ]
        },
        { "type": "section", "title": "Ops" },
        {
          "type": "statlist",
          "title": "Ops (this week)",
          "span": 2,
          "items": [
            { "metric": "ops.todoist_done", "field": "week", "label": "Todoist done" },
            { "metric": "dev.ops_min", "field": "week", "label": "Ops time" },
            { "metric": "dev.field_min", "field": "week", "label": "Field time" }
          ]
        },
        { "type": "section", "title": "Workshop & extras" },
        {
          "type": "statlist",
          "title": "This week",
          "span": 2,
          "items": [
            { "metric": "dev.workshop_min", "field": "week", "label": "Workshop" },
            { "metric": "life.small_talk", "field": "week", "label": "Small talk" },
            { "metric": "dev.reading_min", "field": "week", "label": "Reading" }
          ]
        },
        { "type": "section", "title": "This week's intentions" },
        { "type": "text", "title": "Week theme", "text_key": "text.week_intentions", "span": 4 },
        { "type": "text", "title": "Fitness", "text_key": "text.fitness_intentions", "span": 2 },
        { "type": "text", "title": "Sleep / schedule", "text_key": "text.sleep_intentions", "span": 2 },
        { "type": "text", "title": "Mind / spirit", "text_key": "text.mind_intentions", "span": 2 },
        { "type": "text", "title": "Social", "text_key": "text.social_intentions", "span": 2 },
        { "type": "text", "title": "Parenting", "text_key": "text.parenting_intentions", "span": 2 }
      ]
    },
    {
      "id": "weekly-work",
      "group": "Work",
      "title": "Chrome Lot — This Week",
      "icon": "\ud83d\ude97",
      "subtitle": "Operational + dev throughput. Today vs this week vs trend.",
      "widgets": [
        { "type": "section", "title": "Today" },
        {
          "type": "group",
          "metrics": [
            { "metric": "work.cars_shot", "field": "current", "label": "Cars Shot (today)", "showTrend": true },
            { "metric": "work.cars_shot", "field": "week", "label": "Cars Shot (this wk)", "showTrend": true },
            { "metric": "dev.projects_done", "field": "week", "label": "Projects Done (wk)", "showTrend": true },
            { "metric": "dev.projects_in_progress", "field": "current", "showTrend": false }
          ]
        },
        { "type": "section", "title": "Dev + ops time this week" },
        {
          "type": "group",
          "metrics": [
            { "metric": "dev.total_dev_min", "field": "week", "showTrend": true },
            { "metric": "dev.cl_dev_min", "field": "week", "showTrend": true },
            { "metric": "dev.tg_dev_min", "field": "week", "showTrend": true },
            { "metric": "dev.ops_min", "field": "week", "showTrend": true }
          ]
        },
        { "type": "section", "title": "Trends" },
        { "type": "trend", "metric": "work.cars_shot", "range": 28, "chart": "bar", "span": 2 },
        { "type": "trend", "metric": "dev.total_dev_min", "range": 28, "chart": "bar", "span": 2 },
        { "type": "trend", "metric": "trend.energy_rating", "range": 56, "chart": "line", "span": 2 },
        { "type": "trend", "metric": "trend.mood_valence", "range": 56, "chart": "line", "span": 2 }
      ]
    },
    {
      "id": "finance",
      "group": "Personal",
      "title": "Finance",
      "icon": "\ud83d\udcb0",
      "subtitle": "DEPRIORITIZED — populated once SimpleFIN is connected. See dev project subtasks.",
      "hidden": false,
      "widgets": [
        { "type": "note", "text": "Financial widgets are deprioritized. Once SimpleFIN Bridge is connected on lcc-hub, add a finance-snapshot collector and reference finance.* metrics here (net worth, spend MTD, per-account balances, holdings). Tracked as sub-items under the dashboard Dev Project." }
      ]
    }
  ]
}
