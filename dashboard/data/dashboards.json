        { "type": "stat", "metric": "work.jobs_done", "field": "weekAvg", "label": "Avg jobs/day", "showTrend": false },
        { "type": "stat", "metric": "work.cars_shot", "field": "weekAvg", "label": "Avg cars/day", "showTrend": false },
