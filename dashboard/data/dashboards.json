{
  "_comment": "Dashboard layouts. EDIT THIS FILE to add/rearrange dashboards and widgets — no code changes needed. `group` buckets a dashboard in the sidebar (e.g. Personal / Work). Widget types: section | stat | goal | group | trend | progress | text | note. Reference a metric by its catalog key (metrics.json). 'field' selects the number for stat/goal/trend/progress: current (headline: latest for last-metrics, today for sum/count) | week (this-week aggregate). 'span' (1-4) = column width. Order in the array = order on screen.",
  "settings": {
    "refreshSeconds": 900,
    "columns": 4
  },
  "dashboards": [
    {
      "id": "personal-day",
      "group": "Personal",
      "title": "Personal — Today",
      "icon": "\u2600\ufe0f",
      "subtitle": "Today's priorities: movement, spirit, tracked time, and body basics.",
      "widgets": [
        { "type": "section", "title": "Did I move today?" },
        { "type": "goal", "metric": "life.strength_sessions", "field": "current", "target": 1, "label": "Strength" },
        { "type": "goal", "metric": "life.cardio_sessions", "field": "current", "target": 1, "label": "Cardio" },
        { "type": "stat", "metric": "life.spirit_min", "field": "current", "label": "Spirit", "showTrend": true },
        { "type": "stat", "metric": "life.morning_stack_pct", "field": "current", "label": "Morning Stack", "showTrend": false },
        { "type": "section", "title": "Time tracked today" },
        {
          "type": "group",
          "metrics": [
            { "metric": "dev.total_dev_min", "field": "current", "label": "Total Dev", "showTrend": false },
            { "metric": "dev.workshop_min", "field": "current", "label": "Workshop", "showTrend": false },
            { "metric": "dev.ops_min", "field": "current", "label": "Ops", "showTrend": false },
            { "metric": "dev.admin_min", "field": "current", "label": "Admin", "showTrend": false },
            { "metric": "dev.reading_min", "field": "current", "label": "Reading", "showTrend": false }
          ]
        },
        { "type": "section", "title": "Body" },
        {
          "type": "group",
          "metrics": [
            { "metric": "personal.weight_lbs", "field": "current", "label": "Weigh-in", "showTrend": true },
            { "metric": "personal.sleep_hours", "field": "current", "label": "Sleep", "showTrend": true },
            { "metric": "personal.steps", "field": "current", "label": "Steps", "showTrend": true },
            { "metric": "personal.resting_hr", "field": "current", "label": "Resting HR", "showTrend": true }
          ]
        },
        { "type": "section", "title": "Trends" },
        { "type": "trend", "metric": "personal.weight_lbs", "range": 60, "chart": "line", "span": 2 },
        { "type": "trend", "metric": "personal.body_fat_pct", "range": 60, "chart": "line", "span": 2 },
        { "type": "trend", "metric": "personal.sleep_hours", "range": 30, "chart": "bar", "span": 2 },
        { "type": "trend", "metric": "personal.steps", "range": 30, "chart": "bar", "span": 2 }
      ]
    },
    {
      "id": "personal-week",
      "group": "Personal",
      "title": "Personal — This Week",
      "icon": "\ud83c\udfaf",
      "subtitle": "Progress on the goals I set in the weekly plan (week starts Sunday).",
      "widgets": [
        { "type": "section", "title": "Goal progress" },
        { "type": "progress", "label": "Strength workouts", "metric": "life.strength_sessions", "field": "week", "target": "goal.strength_target", "span": 2 },
        { "type": "progress", "label": "Cardio sessions", "metric": "life.cardio_sessions", "field": "week", "target": "goal.cardio_target", "span": 2 },
        { "type": "progress", "label": "Sleep (avg vs target)", "metric": "personal.sleep_hours", "field": "week", "target": "goal.sleep_target_hours", "span": 2 },
        { "type": "progress", "label": "Small talk / sarges", "metric": "life.small_talk", "field": "week", "targetValue": 5, "span": 2 },
        { "type": "section", "title": "This week's intentions" },
        { "type": "text", "title": "Week theme", "text_key": "text.week_intentions", "span": 4 },
        { "type": "text", "title": "Fitness", "text_key": "text.fitness_intentions", "span": 2 },
        { "type": "text", "title": "Sleep / schedule", "text_key": "text.sleep_intentions", "span": 2 },
        { "type": "text", "title": "Mind / spirit", "text_key": "text.mind_intentions", "span": 2 },
        { "type": "text", "title": "Social", "text_key": "text.social_intentions", "span": 2 },
        { "type": "text", "title": "Parenting", "text_key": "text.parenting_intentions", "span": 2 },
        { "type": "section", "title": "Where I am right now" },
        {
          "type": "group",
          "metrics": [
            { "metric": "life.strength_sessions", "field": "week", "label": "Strength (wk)" },
            { "metric": "life.cardio_sessions", "field": "week", "label": "Cardio (wk)" },
            { "metric": "life.spirit_min", "field": "week", "label": "Spirit (wk)" },
            { "metric": "life.small_talk", "field": "week", "label": "Small talk (wk)" }
          ]
        }
      ]
    },
    {
      "id": "weekly-work",
      "group": "Work",
      "title": "Chrome Lot — This Week",
      "icon": "\ud83d\ude97",
      "subtitle": "Operational + dev throughput. Today vs this week vs trend.",
      "widgets": [
        { "type": "section", "title": "Today" },
        {
          "type": "group",
          "metrics": [
            { "metric": "work.cars_shot", "field": "current", "label": "Cars Shot (today)", "showTrend": true },
            { "metric": "work.cars_shot", "field": "week", "label": "Cars Shot (this wk)", "showTrend": true },
            { "metric": "dev.projects_done", "field": "week", "label": "Projects Done (wk)", "showTrend": true },
            { "metric": "dev.projects_in_progress", "field": "current", "showTrend": false }
          ]
        },
        { "type": "section", "title": "Dev + ops time this week" },
        {
          "type": "group",
          "metrics": [
            { "metric": "dev.total_dev_min", "field": "week", "showTrend": true },
            { "metric": "dev.cl_dev_min", "field": "week", "showTrend": true },
            { "metric": "dev.tg_dev_min", "field": "week", "showTrend": true },
            { "metric": "dev.ops_min", "field": "week", "showTrend": true }
          ]
        },
        { "type": "section", "title": "Trends" },
        { "type": "trend", "metric": "work.cars_shot", "range": 28, "chart": "bar", "span": 2 },
        { "type": "trend", "metric": "dev.total_dev_min", "range": 28, "chart": "bar", "span": 2 },
        { "type": "trend", "metric": "trend.energy_rating", "range": 56, "chart": "line", "span": 2 },
        { "type": "trend", "metric": "trend.mood_valence", "range": 56, "chart": "line", "span": 2 }
      ]
    },
    {
      "id": "finance",
      "group": "Personal",
      "title": "Finance",
      "icon": "\ud83d\udcb0",
      "subtitle": "DEPRIORITIZED — populated once SimpleFIN is connected. See dev project subtasks.",
      "hidden": false,
      "widgets": [
        { "type": "note", "text": "Financial widgets are deprioritized. Once SimpleFIN Bridge is connected on lcc-hub, add a finance-snapshot collector and reference finance.* metrics here (net worth, spend MTD, per-account balances, holdings). Tracked as sub-items under the dashboard Dev Project." }
      ]
    }
  ]
}
