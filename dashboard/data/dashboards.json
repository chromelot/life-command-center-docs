{
  "_comment": "Dashboard layouts. EDIT THIS FILE to add/rearrange dashboards and widgets — no code changes needed. `group` buckets a dashboard in the sidebar (e.g. Personal / Work). Widget types: section | stat | goal | group | trend | progress | text | note. Reference a metric by its catalog key (metrics.json). 'field' selects the number for stat/goal/trend/progress: current (headline: latest for last-metrics, today for sum/count) | week (this-week aggregate). 'span' (1-4) = column width. Order in the array = order on screen.",
  "settings": {
    "refreshSeconds": 900,
    "columns": 4
  },
  "dashboards": [
    {
      "id": "personal-day",
      "group": "Personal",
      "title": "Personal — Today",
      "icon": "\u2600\ufe0f",
      "subtitle": "How today is going, at a glance.",
      "widgets": [
        { "type": "section", "title": "Morning" },
        {
          "type": "checklist",
          "title": "Morning stack",
          "span": 2,
          "items": [
            { "metric": "life.supplements_done", "label": "Supplements" },
            { "metric": "life.weigh_in_done", "label": "Weigh in" },
            { "metric": "life.morning_journal_done", "label": "Morning journal" },
            { "metric": "life.spirit_time_done", "label": "Spirit time" }
          ]
        },
        { "type": "section", "title": "Fitness" },
        { "type": "goal", "metric": "life.strength_sessions", "field": "current", "target": 1, "weekTargetMetric": "goal.strength_target", "label": "Strength", "detail": "workouts", "detailFilter": { "type": ["Pull", "Push", "Legs", "Deadlift", "Full Body"] } },
        { "type": "goal", "metric": "life.cardio_sessions", "field": "current", "target": 1, "weekTargetMetric": "goal.cardio_target", "label": "Cardio", "detail": "workouts", "detailFilter": { "type": ["Cardio"] } },
        { "type": "stat", "metric": "personal.steps", "field": "current", "label": "Steps", "showTrend": false },
        { "type": "section", "title": "Nutrition" },
        {
          "type": "progressgroup",
          "title": "Calories & Protein",
          "span": 2,
          "items": [
            { "metric": "nutrition.calories", "field": "current", "target": "goal.calorie_target", "label": "Calories", "detail": "nutrition", "detailTitle": "Food log" },
            { "metric": "nutrition.protein_g", "field": "current", "targetValue": 150, "label": "Protein", "detail": "nutrition", "detailTitle": "Food log" }
          ]
        },
        {
          "type": "statlist",
          "title": "Macros",
          "span": 2,
          "items": [
            { "metric": "nutrition.protein_g", "field": "current", "label": "Protein", "detail": "nutrition", "detailTitle": "Food log" },
            { "metric": "nutrition.carbs_g", "field": "current", "label": "Carbs", "detail": "nutrition", "detailTitle": "Food log" },
            { "metric": "nutrition.fat_g", "field": "current", "label": "Fat", "detail": "nutrition", "detailTitle": "Food log" }
          ]
        },
        { "type": "section", "title": "Development work" },
        { "type": "stat", "metric": "dev.cl_dev_min", "field": "current", "label": "Chrome Lot", "showTrend": false, "detail": "timepunches", "detailFilter": { "category": ["CL Dev"] } },
        { "type": "stat", "metric": "dev.tg_dev_min", "field": "current", "label": "Turbo Gear", "showTrend": false, "detail": "timepunches", "detailFilter": { "category": ["TG Dev"] } },
        { "type": "stat", "metric": "dev.systems_min", "field": "current", "label": "Systems", "showTrend": false, "detail": "timepunches", "detailFilter": { "category": ["Systems"] } },
        { "type": "goal", "metric": "dev.total_dev_min", "field": "current", "target": 120, "weekTarget": 600, "label": "Total Dev", "detail": "timepunches", "detailFilter": { "category": ["CL Dev", "TG Dev", "Systems"] }, "detailTitle": "Dev time log" },
        { "type": "section", "title": "Ops" },
        { "type": "stat", "metric": "ops.todoist_done", "field": "current", "label": "Todoist Done", "showTrend": false, "detail": "todoist" },
        { "type": "stat", "metric": "dev.ops_min", "field": "current", "label": "Ops Time", "showTrend": false, "detail": "timepunches", "detailFilter": { "category": ["Ops"] } },
        { "type": "stat", "metric": "dev.field_min", "field": "current", "label": "Field Time", "showTrend": false, "detail": "timepunches", "detailFilter": { "category": ["Field"] } },
        { "type": "goal", "metric": "dev.total_ops_work_min", "field": "current", "target": 120, "weekTarget": 600, "label": "Total Ops Work", "detail": "timepunches", "detailFilter": { "category": ["Ops", "Field"] }, "detailTitle": "Ops time log" },
        { "type": "section", "title": "Workshop & extras" },
        {
          "type": "group",
          "metrics": [
            { "metric": "dev.workshop_min", "field": "current", "label": "Workshop", "showTrend": false, "detail": "timepunches", "detailFilter": { "category": ["Workshop"] } },
            { "metric": "life.small_talk", "field": "current", "label": "Small Talk", "showTrend": false, "detail": "smalltalk" },
            { "metric": "dev.reading_min", "field": "current", "label": "Reading", "showTrend": false, "detail": "timepunches", "detailFilter": { "category": ["Reading"] } }
          ]
        }
      ]
    },
    {
      "id": "personal-week",
      "group": "Personal",
      "title": "Personal — This Week",
      "icon": "\ud83c\udfaf",
      "subtitle": "This week's scorecard (starts Sunday) — where I'm on track and where to push. Same data as Today, pivoted to the week.",
      "widgets": [
        { "type": "section", "title": "Morning — days done this week" },
        {
          "type": "progressgroup",
          "title": "Morning stack (goal 6 days)",
          "span": 2,
          "items": [
            { "metric": "life.supplements_done", "field": "week", "targetValue": 6, "format": "integer", "label": "Supplements" },
            { "metric": "life.weigh_in_done", "field": "week", "targetValue": 6, "format": "integer", "label": "Weigh in" },
            { "metric": "life.morning_journal_done", "field": "week", "targetValue": 6, "format": "integer", "label": "Morning journal" },
            { "metric": "life.spirit_time_done", "field": "week", "targetValue": 6, "format": "integer", "label": "Spirit time" }
          ]
        },
        { "type": "section", "title": "Fitness" },
        {
          "type": "progressgroup",
          "title": "Workouts vs weekly goal",
          "span": 2,
          "items": [
            { "metric": "life.strength_sessions", "field": "week", "target": "goal.strength_target", "label": "Strength", "detail": "workouts", "detailFilter": { "type": ["Pull", "Push", "Legs", "Deadlift", "Full Body"] } },
            { "metric": "life.cardio_sessions", "field": "week", "target": "goal.cardio_target", "label": "Cardio", "detail": "workouts", "detailFilter": { "type": ["Cardio"] } }
          ]
        },
        {
          "type": "statlist",
          "title": "Weekly averages",
          "span": 2,
          "items": [
            { "metric": "personal.steps", "field": "weekAvg", "label": "Steps / day" },
            { "metric": "personal.sleep_hours", "field": "weekAvg", "label": "Sleep / night", "minCount": 3 },
            { "metric": "personal.weight_lbs", "field": "weekAvg", "label": "Weight (avg)" },
            { "metric": "personal.body_fat_pct", "field": "weekAvg", "label": "Body fat (avg)" }
          ]
        },
        { "type": "section", "title": "Social" },
        {
          "type": "progressgroup",
          "title": "Social vs weekly goal",
          "span": 2,
          "items": [
            { "metric": "life.small_talk", "field": "week", "target": "goal.social_target", "label": "Small talk / sarges", "detail": "smalltalk" }
          ]
        },
        { "type": "section", "title": "Nutrition — daily average" },
        {
          "type": "progressgroup",
          "title": "Avg / day vs target",
          "span": 2,
          "items": [
            { "metric": "nutrition.calories", "field": "weekAvg", "target": "goal.calorie_target", "label": "Calories", "detail": "nutrition", "detailTitle": "Food log (this week)" },
            { "metric": "nutrition.protein_g", "field": "weekAvg", "targetValue": 150, "label": "Protein", "detail": "nutrition", "detailTitle": "Food log (this week)" }
          ]
        },
        {
          "type": "statlist",
          "title": "Avg macros / day",
          "span": 2,
          "items": [
            { "metric": "nutrition.protein_g", "field": "weekAvg", "label": "Protein", "detail": "nutrition", "detailTitle": "Food log (this week)" },
            { "metric": "nutrition.carbs_g", "field": "weekAvg", "label": "Carbs", "detail": "nutrition", "detailTitle": "Food log (this week)" },
            { "metric": "nutrition.fat_g", "field": "weekAvg", "label": "Fat", "detail": "nutrition", "detailTitle": "Food log (this week)" }
          ]
        },
        { "type": "section", "title": "Development work" },
        {
          "type": "progressgroup",
          "title": "Dev & ops time vs weekly goal",
          "span": 2,
          "items": [
            { "metric": "dev.total_dev_min", "field": "week", "targetValue": 600, "label": "Total Dev", "detail": "timepunches", "detailFilter": { "category": ["CL Dev", "TG Dev", "Systems"] }, "detailTitle": "Dev time log (this week)" },
            { "metric": "dev.total_ops_work_min", "field": "week", "targetValue": 600, "label": "Total Ops Work", "detail": "timepunches", "detailFilter": { "category": ["Ops", "Field"] }, "detailTitle": "Ops time log (this week)" }
          ]
        },
        {
          "type": "statlist",
          "title": "Dev breakdown (this week)",
          "span": 2,
          "items": [
            { "metric": "dev.cl_dev_min", "field": "week", "label": "Chrome Lot", "detail": "timepunches", "detailFilter": { "category": ["CL Dev"] } },
            { "metric": "dev.tg_dev_min", "field": "week", "label": "Turbo Gear", "detail": "timepunches", "detailFilter": { "category": ["TG Dev"] } },
            { "metric": "dev.systems_min", "field": "week", "label": "Systems", "detail": "timepunches", "detailFilter": { "category": ["Systems"] } }
          ]
        },
        { "type": "section", "title": "Ops" },
        {
          "type": "statlist",
          "title": "Ops (this week)",
          "span": 2,
          "items": [
            { "metric": "ops.todoist_done", "field": "week", "label": "Todoist done", "detail": "todoist" },
            { "metric": "dev.ops_min", "field": "week", "label": "Ops time", "detail": "timepunches", "detailFilter": { "category": ["Ops"] } },
            { "metric": "dev.field_min", "field": "week", "label": "Field time", "detail": "timepunches", "detailFilter": { "category": ["Field"] } }
          ]
        },
        { "type": "section", "title": "Workshop & extras" },
        {
          "type": "statlist",
          "title": "This week",
          "span": 2,
          "items": [
            { "metric": "dev.workshop_min", "field": "week", "label": "Workshop", "detail": "timepunches", "detailFilter": { "category": ["Workshop"] } },
            { "metric": "dev.reading_min", "field": "week", "label": "Reading", "detail": "timepunches", "detailFilter": { "category": ["Reading"] } }
          ]
        },
        { "type": "section", "title": "Adjustments & experiments this week" },
        { "type": "note", "text": "Qualitative focus only — the numeric targets live in the widgets above. These are the behavioral changes / experiments I'm making this week.", "span": 4 },
        { "type": "text", "title": "Week theme", "text_key": "text.week_intentions", "span": 4 },
        { "type": "text", "title": "Fitness", "text_key": "text.fitness_intentions", "span": 2 },
        { "type": "text", "title": "Sleep / schedule", "text_key": "text.sleep_intentions", "span": 2 },
        { "type": "text", "title": "Mind / spirit", "text_key": "text.mind_intentions", "span": 2 },
        { "type": "text", "title": "Social", "text_key": "text.social_intentions", "span": 2 },
        { "type": "text", "title": "Parenting", "text_key": "text.parenting_intentions", "span": 2 }
      ]
    },
    {
      "id": "personal-month",
      "group": "Personal",
      "title": "Personal — Trends",
      "icon": "\ud83d\udcc8",
      "subtitle": "Weekly trends over the last ~12 weeks. Click a week on any chart to see what you did.",
      "widgets": [
        { "type": "section", "title": "Dev throughput / week" },
        {
          "type": "weektrend",
          "title": "Completed tasks per week",
          "weeks": 12,
          "span": 4,
          "series": [
            { "metric": "dev.projects_done", "label": "Notion dev tasks", "color": "#4f8cff", "detail": "projects_done" },
            { "metric": "ops.todoist_done", "label": "Todoist tasks", "color": "#39d98a", "detail": "todoist" }
          ]
        },
        { "type": "section", "title": "Time / week" },
        {
          "type": "weektrend",
          "title": "Dev & ops minutes per week",
          "weeks": 12,
          "span": 4,
          "series": [
            { "metric": "dev.total_dev_min", "label": "Total Dev", "color": "#4f8cff", "detail": "timepunches", "detailFilter": { "category": ["CL Dev", "TG Dev", "Systems"] } },
            { "metric": "dev.total_ops_work_min", "label": "Total Ops Work", "color": "#f6c453", "detail": "timepunches", "detailFilter": { "category": ["Ops", "Field"] } }
          ]
        },
        { "type": "section", "title": "Fitness & social / week" },
        {
          "type": "weektrend",
          "title": "Workouts per week",
          "weeks": 12,
          "span": 2,
          "series": [
            { "metric": "life.strength_sessions", "label": "Strength", "color": "#4f8cff", "detail": "workouts", "detailFilter": { "type": ["Pull", "Push", "Legs", "Deadlift", "Full Body"] } },
            { "metric": "life.cardio_sessions", "label": "Cardio", "color": "#39d98a", "detail": "workouts", "detailFilter": { "type": ["Cardio"] } }
          ]
        },
        {
          "type": "weektrend",
          "title": "Small talk per week",
          "weeks": 12,
          "span": 2,
          "series": [
            { "metric": "life.small_talk", "label": "Small talk", "color": "#b57bff", "detail": "smalltalk" }
          ]
        },
        { "type": "section", "title": "Body" },
        {
          "type": "weektrend",
          "title": "Weight (weekly avg)",
          "weeks": 12,
          "span": 2,
          "series": [{ "metric": "personal.weight_lbs", "label": "Weight (lb)", "color": "#f6c453" }]
        },
        {
          "type": "weektrend",
          "title": "Sleep (avg hrs / night)",
          "weeks": 12,
          "span": 2,
          "series": [{ "metric": "personal.sleep_hours", "label": "Sleep (h)", "color": "#4f8cff" }]
        }
      ]
    },
    {
      "id": "work-day",
      "group": "Work",
      "title": "Chrome Lot — Today",
      "icon": "\ud83d\ude97",
      "subtitle": "Today's schedule and team status. Pick a day to look back.",
